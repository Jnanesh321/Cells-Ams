generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  PARENT
  FACULTY
  HOD
  PRINCIPAL
  ADMIN
  ADMISSION_CELL
  EXAM_CELL
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  OD
}

enum CounsellingStatus {
  DUE
  COMPLETED
  OVERDUE
}

model Department {
  id        Int       @id @default(autoincrement())
  name      String
  code      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  users     User[]
  subjects  Subject[]
  notices   Notice[]
  dayOverrides     DayOverride[]
  counsellorAssignments CounsellorAssignment[]

  @@map("departments")
}

model User {
  id             Int       @id @default(autoincrement())
  usn            String    @unique
  name           String
  email                 String?   @unique
  emailVerified         Boolean   @default(false)
  emailVerificationToken String?
  emailVerificationSentAt DateTime?
  lastVerifiedAt        DateTime?
  passwordHash          String
  role                  Role
  isActive              Boolean   @default(true)
  departmentId   Int?
  department     Department? @relation(fields: [departmentId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  studentProfile    StudentProfile?
  facultyProfile    FacultyProfile?
  parentLinks       ParentStudent[]   @relation("ParentLinks")
  childLinks        ParentStudent[]    @relation("StudentLinks")
  refreshTokens     RefreshToken[]
  markedAttendance  AttendanceRecord[] @relation("MarkedBy")
  enteredIAMarks    IAMark[]           @relation("EnteredIAMarks")
  assignedClasses   ClassAssignment[]  @relation("AssignedBy")
  postedNotices     Notice[]           @relation("PostedBy")
  enteredAssignmentMarks AssignmentMark[] @relation("EnteredAssignmentMarks")
  finalizedCIE      CIESummary[]       @relation("FinalizedCIE")
  exemptedDetentions DetentionRecord[]  @relation("ExemptedDetention")
  birthdayVisibility BirthdayVisibility?

  // Counselling System
  counsellorFacultyAssignments   CounsellorAssignment[] @relation("CounsellorFaculty")
  counsellorStudentAssignments   CounsellorAssignment[] @relation("CounsellorStudent")
  counsellorAssignmentsCreated   CounsellorAssignment[] @relation("CounsellorAssignedBy")

  // VTU IA System
  enteredVTUIAMarks              VTUIAMark[]            @relation("EnteredVTUIAMarks")
  vtuFinalizedCIE                VTUCIESummary[]        @relation("VTUFinalizedCIE")

  // Question Paper & IA Marks System
  createdQuestionPapers          IAQuestionPaper[]      @relation("CreatedQuestionPapers")
  enteredIAStudentSubMarks       IAStudentSubMark[]     @relation("EnteredIAStudentSubMarks")
  markedIAAbsentees              IAAbsentee[]           @relation("MarkedIAAbsentees")
  enteredLabIAMarks              LabIAMark[]            @relation("EnteredLabIAMarks")
  createdLabIAConfigs            LabIAConfig[]          @relation("CreatedLabIAConfigs")
  notifications                  Notification[]

  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model StudentProfile {
  id        Int    @id @default(autoincrement())
  userId    Int    @unique
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  semester  String
  section   String
  batch     String @default("2021-2025")
  dateOfBirth DateTime? @db.Date

  // Personal
  fatherName       String?
  motherName       String?
  fatherOccupation String?
  motherOccupation String?
  fatherPhone      String?
  motherPhone      String?
  studentPhone     String?
  permanentAddress String?
  currentAddress   String?
  bloodGroup       String?
  nationality      String?  @default("Indian")
  religion         String?
  category         String?  // General, OBC, SC, ST

  // Previous education
  tenthMarks       Float?
  tenthBoard       String?
  tenthPassYear    Int?
  pucMarks         Float?
  pucBoard         String?
  pucPassYear      Int?
  cetRank          Int?
  cetScore         Float?
  diplomaMarks     Float?

  // Additional
  hobbies          String?
  achievements     String?
  isLateralEntry   Boolean  @default(false)
  admissionType    String?
  photoUrl         String?

  attendance           AttendanceRecord[]
  iaMarks              IAMark[]
  assignmentMarks      AssignmentMark[]
  cieSummaries         CIESummary[]
  detentionRecords     DetentionRecord[]
  vtuIAMarks           VTUIAMark[]
  vtuCIESummaries      VTUCIESummary[]

  // Question Paper & IA Marks System
  iaSubMarks           IAStudentSubMark[]
  iaAbsenteeRecords    IAAbsentee[]
  labIAMarks           LabIAMark[]

  @@map("student_profiles")
}

model FacultyProfile {
  id          Int    @id @default(autoincrement())
  userId      Int    @unique
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  designation String @default("Assistant Professor")
  dateOfBirth DateTime? @db.Date

  subjectMappings  SubjectMapping[]
  classAssignments ClassAssignment[]

  @@map("faculty_profiles")
}

model ParentStudent {
  id        Int  @id @default(autoincrement())
  parentId  Int
  studentId Int
  parent    User @relation("ParentLinks", fields: [parentId], references: [id], onDelete: Cascade)
  student   User @relation("StudentLinks", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@map("parent_students")
}

model Subject {
  id           Int        @id @default(autoincrement())
  code         String     @unique
  name         String
  semester     String
  credits      Int        @default(4)
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  subjectMappings  SubjectMapping[]
  attendance       AttendanceRecord[]
  iaMarks          IAMark[]
  classAssignments ClassAssignment[]
  assignmentMarks  AssignmentMark[]
  cieSummaries     CIESummary[]
  timetableEntries TimetableEntry[]
  vtuIAMarks       VTUIAMark[]
  vtuCIESummaries  VTUCIESummary[]

  questionPapers   IAQuestionPaper[]
  iaAbsenteeRecords IAAbsentee[]
  labIAMarks       LabIAMark[]
  labIAConfigs     LabIAConfig[]

  @@map("subjects")
}

model SubjectMapping {
  id               Int            @id @default(autoincrement())
  subjectId        Int
  facultyProfileId Int
  section          String
  academicYear     String
  createdAt        DateTime       @default(now())

  subject Subject        @relation(fields: [subjectId], references: [id])
  faculty FacultyProfile @relation(fields: [facultyProfileId], references: [id])

  @@unique([subjectId, section, academicYear])
  @@map("subject_mappings")
}

model AttendanceRecord {
  id               Int              @id @default(autoincrement())
  studentProfileId Int
  subjectId        Int
  date             DateTime         @db.Date
  status           AttendanceStatus
  markedByUserId   Int
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  subject        Subject        @relation(fields: [subjectId], references: [id])
  markedBy       User           @relation("MarkedBy", fields: [markedByUserId], references: [id])

  @@unique([studentProfileId, subjectId, date])
  @@index([studentProfileId])
  @@index([subjectId, date])
  @@map("attendance_records")
}

model IAMark {
  id               Int      @id @default(autoincrement())
  studentProfileId Int
  subjectId        Int
  iaNumber         Int
  marksObtained    Float
  maxMarks         Float    @default(30)
  enteredByUserId  Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  subject        Subject        @relation(fields: [subjectId], references: [id])
  enteredBy      User           @relation("EnteredIAMarks", fields: [enteredByUserId], references: [id])

  @@unique([studentProfileId, subjectId, iaNumber])
  @@index([studentProfileId])
  @@map("ia_marks")
}

model Notice {
  id             Int       @id @default(autoincrement())
  title          String
  content        String    @db.Text
  targetRole     Role?
  departmentId   Int?
  postedByUserId Int
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  department Department? @relation(fields: [departmentId], references: [id])
  postedBy   User        @relation("PostedBy", fields: [postedByUserId], references: [id])

  @@index([targetRole])
  @@index([departmentId])
  @@map("notices")
}

model AcademicCalendar {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  startDate   DateTime  @db.Date
  endDate     DateTime? @db.Date
  type        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("academic_calendar")
}

model ClassAssignment {
  id               Int      @id @default(autoincrement())
  facultyProfileId Int
  subjectId        Int
  section          String
  semester         String
  academicYear     String
  isActive         Boolean  @default(true)
  assignedByUserId Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  faculty    FacultyProfile @relation(fields: [facultyProfileId], references: [id])
  subject    Subject        @relation(fields: [subjectId], references: [id])
  assignedBy User           @relation("AssignedBy", fields: [assignedByUserId], references: [id])

  @@unique([subjectId, section, academicYear])
  @@index([facultyProfileId, isActive])
  @@map("class_assignments")
}

model RollNumberSequence {
  id         Int    @id @default(autoincrement())
  department String
  year       Int
  lastRollNo Int    @default(0)

  @@unique([department, year])
  @@map("roll_number_sequences")
}

model StudentDraft {
  id            Int      @id @default(autoincrement())
  rollNo        String   @unique
  name          String
  gender        String   @default("MALE")
  phone         String?
  parentPhone   String?
  admissionType String   @default("CET")
  department    String
  section       String
  mappedUSN     String?
  batchId       String?
  academicYear  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([department, academicYear])
  @@index([mappedUSN])
  @@map("student_drafts")
}

model AdmissionBatch {
  id         String   @id
  department String
  year       Int
  section    String
  intakeSize Int
  startRollNo Int
  endRollNo  Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([department, year])
  @@map("admission_batches")
}

model AssignmentMark {
  id               Int      @id @default(autoincrement())
  studentProfileId Int
  subjectId        Int
  assignmentNumber Int
  marksObtained    Float
  maxMarks         Float    @default(10)
  enteredByUserId  Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  subject        Subject        @relation(fields: [subjectId], references: [id])
  enteredBy      User           @relation("EnteredAssignmentMarks", fields: [enteredByUserId], references: [id])

  @@unique([studentProfileId, subjectId, assignmentNumber])
  @@index([studentProfileId])
  @@map("assignment_marks")
}

model CIESummary {
  id               Int      @id @default(autoincrement())
  studentProfileId Int
  subjectId        Int
  iaBestTwo        Float    @default(0)
  cieFromIA        Float    @default(0)
  assignmentTotal  Float    @default(0)
  cieTotal         Float    @default(0)
  isEligible       Boolean  @default(true)
  finalized        Boolean  @default(false)
  finalizedByUserId Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  subject        Subject        @relation(fields: [subjectId], references: [id])
  finalizedBy    User?          @relation("FinalizedCIE", fields: [finalizedByUserId], references: [id])

  @@unique([studentProfileId, subjectId])
  @@index([studentProfileId])
  @@map("cie_summaries")
}

model DetentionRecord {
  id               Int      @id @default(autoincrement())
  studentProfileId Int
  academicYear     String
  semester         String
  isDetained       Boolean  @default(false)
  detentionReasons String[]
  attendancePercent Float   @default(0)
  cieTotal         Float    @default(0)
  exempted         Boolean  @default(false)
  exemptedByUserId Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  exemptedBy     User?          @relation("ExemptedDetention", fields: [exemptedByUserId], references: [id])

  @@unique([studentProfileId, academicYear, semester])
  @@index([academicYear, semester])
  @@map("detention_records")
}

// ========= ACADEMIC DAY SYSTEM =========

model AcademicDayState {
  id             Int      @id @default(autoincrement())
  currentDay     Int      @default(1)
  lastUpdated    DateTime @updatedAt
  academicYear   String   @default("2025-2026")
  isActive       Boolean  @default(true)

  @@map("academic_day_state")
}

model DayOverride {
  id          Int      @id @default(autoincrement())
  date        DateTime @db.Date
  dayType     String   // "holiday" | "exam" | "suspended" | "event" | "working"
  title       String?
  departmentId Int?
  department  Department? @relation(fields: [departmentId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([date])
  @@index([departmentId])
  @@map("day_overrides")
}

model Period {
  id        Int      @id @default(autoincrement())
  name      String   // "Period 1", "Period 2", etc.
  startTime String   // "09:00"
  endTime   String   // "09:50"
  type      String   @default("lecture") // "lecture" | "lab"
  order     Int      // 1, 2, 3...

  timetableEntries TimetableEntry[]
  @@map("periods")
}

model TimetableEntry {
  id         Int      @id @default(autoincrement())
  dayNumber  Int      // 1-6
  periodId   Int
  subjectId  Int
  section    String
  semester   String
  academicYear String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  period  Period  @relation(fields: [periodId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([dayNumber, periodId, section, academicYear])
  @@index([dayNumber, section])
  @@index([subjectId])
  @@map("timetable_entries")
}

// ========= BIRTHDAY SYSTEM =========

model BirthdayVisibility {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("birthday_visibility")
}

// ========= COUNSELLING SYSTEM =========

model CounsellorAssignment {
  id              Int      @id @default(autoincrement())
  facultyUserId   Int
  faculty         User     @relation("CounsellorFaculty", fields: [facultyUserId], references: [id])
  studentUserId   Int
  student         User     @relation("CounsellorStudent", fields: [studentUserId], references: [id])
  departmentId    Int
  department      Department @relation(fields: [departmentId], references: [id])
  academicYear    String
  isActive        Boolean  @default(true)
  assignedById    Int
  assignedBy      User     @relation("CounsellorAssignedBy", fields: [assignedById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sessions        CounsellingSession[]

  @@unique([facultyUserId, studentUserId, academicYear])
  @@index([facultyUserId, isActive])
  @@index([studentUserId])
  @@index([departmentId])
  @@map("counsellor_assignments")
}

model CounsellingSession {
  id                Int      @id @default(autoincrement())
  studentUserId     Int
  facultyUserId     Int
  assignmentId      Int

  // SECTION 1: Faculty Observation
  observation       String   @db.Text

  // SECTION 2: Student Current Status
  studentStatus     String   @db.Text

  // SECTION 3: Faculty Guidance
  guidance          String   @db.Text

  // SECTION 4: Follow-up
  followUp          String   @db.Text
  nextSessionDate   DateTime? @db.Date

  status            CounsellingStatus @default(DUE)
  sessionDate       DateTime @default(now()) @db.Date
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  assignment        CounsellorAssignment @relation(fields: [assignmentId], references: [id])

  @@index([assignmentId])
  @@index([studentUserId])
  @@index([facultyUserId])
  @@index([sessionDate])
  @@map("counselling_sessions")
}

// ========= VTU IA SYSTEM =========

model VTUIAMark {
  id               Int      @id @default(autoincrement())
  studentProfileId Int
  subjectId        Int
  iaNumber         Int           // 1, 2, or 3

  q1               Float    @default(0)  // 0-25
  q2               Float    @default(0)  // 0-25
  q3               Float    @default(0)  // 0-25
  q4               Float    @default(0)  // 0-25

  sectionA         Float    @default(0)  // auto max(q1,q2)
  sectionB         Float    @default(0)  // auto max(q3,q4)
  total            Float    @default(0)  // auto sectionA+sectionB

  enteredByUserId  Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  subject        Subject        @relation(fields: [subjectId], references: [id])
  enteredBy      User           @relation("EnteredVTUIAMarks", fields: [enteredByUserId], references: [id])

  @@unique([studentProfileId, subjectId, iaNumber])
  @@index([studentProfileId])
  @@map("vtu_ia_marks")
}

model VTUCIESummary {
  id               Int      @id @default(autoincrement())
  studentProfileId Int
  subjectId        Int

  ia1Total         Float    @default(0)  // total from VTUIAMark iaNumber=1
  ia2Total         Float    @default(0)  // total from VTUIAMark iaNumber=2
  ia3Total         Float    @default(0)  // total from VTUIAMark iaNumber=3

  bestTwoTotal     Float    @default(0)  // sum of best 2
  finalCIE         Float    @default(0)  // bestTwoTotal (max 50)
  isEligible       Boolean  @default(true)
  finalized        Boolean  @default(false)
  finalizedByUserId Int?

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  subject        Subject        @relation(fields: [subjectId], references: [id])
  finalizedBy    User?          @relation("VTUFinalizedCIE", fields: [finalizedByUserId], references: [id])

  @@unique([studentProfileId, subjectId])
  @@index([studentProfileId])
  @@map("vtu_cie_summaries")
}

// ========= QUESTION PAPER & IA MARKS SYSTEM =========

model IAQuestionPaper {
  id            Int      @id @default(autoincrement())
  subjectId     Int
  iaNumber      Int                    // 1, 2, or 3
  semester      String
  section       String
  academicYear  String
  totalMarks    Float    @default(50)
  duration      Int      @default(90)  // minutes
  isActive      Boolean  @default(true)
  createdByUserId Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subject    Subject       @relation(fields: [subjectId], references: [id])
  createdBy  User          @relation("CreatedQuestionPapers", fields: [createdByUserId], references: [id])
  questions  IAQuestion[]

  @@unique([subjectId, iaNumber, section, academicYear])
  @@index([subjectId])
  @@map("ia_question_papers")
}

model IAQuestion {
  id               Int      @id @default(autoincrement())
  questionPaperId  Int
  questionNumber   Int                    // 1, 2, 3, or 4
  text             String?                // optional prompt text
  maxMarks         Float    @default(25)
  createdAt        DateTime @default(now())

  questionPaper IAQuestionPaper @relation(fields: [questionPaperId], references: [id], onDelete: Cascade)
  subQuestions  IASubQuestion[]

  @@unique([questionPaperId, questionNumber])
  @@map("ia_questions")
}

model IASubQuestion {
  id          Int      @id @default(autoincrement())
  questionId  Int
  label       String                 // "a", "b", "c", "d"
  maxMarks    Float    @default(6)
  text        String?                // optional sub-question text
  createdAt   DateTime @default(now())

  question       IAQuestion          @relation(fields: [questionId], references: [id], onDelete: Cascade)
  studentSubMarks IAStudentSubMark[]

  @@unique([questionId, label])
  @@map("ia_sub_questions")
}

model IAStudentSubMark {
  id               Int      @id @default(autoincrement())
  studentProfileId Int
  subQuestionId    Int
  marksObtained    Float    @default(0)
  enteredByUserId  Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  subQuestion    IASubQuestion  @relation(fields: [subQuestionId], references: [id], onDelete: Cascade)
  enteredBy      User           @relation("EnteredIAStudentSubMarks", fields: [enteredByUserId], references: [id])

  @@unique([studentProfileId, subQuestionId])
  @@index([studentProfileId])
  @@map("ia_student_sub_marks")
}

model IAAbsentee {
  id               Int      @id @default(autoincrement())
  studentProfileId Int
  subjectId        Int
  iaNumber         Int
  markedByUserId   Int
  createdAt        DateTime @default(now())

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  subject        Subject        @relation(fields: [subjectId], references: [id])
  markedBy       User           @relation("MarkedIAAbsentees", fields: [markedByUserId], references: [id])

  @@unique([studentProfileId, subjectId, iaNumber])
  @@index([studentProfileId])
  @@map("ia_absentees")
}

model LabIAMark {
  id                   Int      @id @default(autoincrement())
  studentProfileId     Int
  subjectId            Int
  component            String
  marksObtained        Float    @default(0)
  maxMarks             Float
  externalExaminerName String?
  enteredByUserId      Int
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  subject        Subject        @relation(fields: [subjectId], references: [id])
  enteredBy      User           @relation("EnteredLabIAMarks", fields: [enteredByUserId], references: [id])

  @@unique([studentProfileId, subjectId, component])
  @@index([studentProfileId])
  @@map("lab_ia_marks")
}

model LabIAConfig {
  id              Int      @id @default(autoincrement())
  subjectId       Int
  component       String
  maxMarks        Float
  isExternal      Boolean  @default(false)
  createdByUserId Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subject   Subject @relation(fields: [subjectId], references: [id])
  createdBy User    @relation("CreatedLabIAConfigs", fields: [createdByUserId], references: [id])

  @@unique([subjectId, component])
  @@map("lab_ia_configs")
}

// ========= NOTIFICATION SYSTEM =========

model Notification {
  id          Int      @id @default(autoincrement())
  userId      Int
  title       String
  body        String
  type        String   // attendance, marks, detention, etc
  isRead      Boolean  @default(false)
  relatedId   Int?
  relatedType String?  // "attendance", "marks", etc
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}
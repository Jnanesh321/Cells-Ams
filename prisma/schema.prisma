generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  PARENT
  FACULTY
  HOD
  PRINCIPAL
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  OD
}

model Department {
  id       Int       @id @default(autoincrement())
  name     String
  code     String    @unique
  users    User[]
  subjects Subject[]

  @@map("departments")
}

model User {
  id           Int         @id @default(autoincrement())
  usn          String      @unique
  name         String
  email        String?     @unique
  passwordHash String
  role         Role
  isActive     Boolean     @default(true)
  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])

  studentProfile StudentProfile?
  facultyProfile FacultyProfile?
  parentLinks    ParentStudent[] @relation("ParentLinks")
  childLinks     ParentStudent[] @relation("StudentLinks")
  refreshTokens  RefreshToken[]
  markedAttendance AttendanceRecord[] @relation("MarkedBy")
  enteredMarks     CIEMark[]          @relation("EnteredBy")
  postedNotices    Notice[]           @relation("PostedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model StudentProfile {
  id        Int    @id @default(autoincrement())
  userId    Int    @unique
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  semester  String
  section   String
  batch     String @default("2021-2025")

  attendance AttendanceRecord[]
  marks      CIEMark[]

  @@map("student_profiles")
}

model FacultyProfile {
  id      Int    @id @default(autoincrement())
  userId  Int    @unique
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  designation String @default("Assistant Professor")

  mappings SubjectMapping[]

  @@map("faculty_profiles")
}

model ParentStudent {
  id        Int  @id @default(autoincrement())
  parentId  Int
  studentId Int
  parent    User @relation("ParentLinks", fields: [parentId], references: [id], onDelete: Cascade)
  student   User @relation("StudentLinks", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@map("parent_students")
}

model Subject {
  id           Int        @id @default(autoincrement())
  code         String     @unique
  name         String
  semester     String
  credits      Int        @default(4)
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])

  mappings   SubjectMapping[]
  attendance AttendanceRecord[]
  marks      CIEMark[]

  @@map("subjects")
}

model SubjectMapping {
  id               Int            @id @default(autoincrement())
  subjectId        Int
  facultyProfileId Int
  section          String
  academicYear     String
  subject          Subject        @relation(fields: [subjectId], references: [id])
  faculty          FacultyProfile @relation(fields: [facultyProfileId], references: [id])

  @@unique([subjectId, section, academicYear])
  @@map("subject_mappings")
}

model AttendanceRecord {
  id               Int              @id @default(autoincrement())
  studentProfileId Int
  subjectId        Int
  date             DateTime         @db.Date
  status           AttendanceStatus
  markedByUserId   Int
  studentProfile   StudentProfile   @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  subject          Subject          @relation(fields: [subjectId], references: [id])
  markedBy         User             @relation("MarkedBy", fields: [markedByUserId], references: [id])

  createdAt DateTime @default(now())

  @@unique([studentProfileId, subjectId, date])
  @@index([studentProfileId])
  @@index([subjectId, date])
  @@map("attendance_records")
}

model CIEMark {
  id               Int            @id @default(autoincrement())
  studentProfileId Int
  subjectId        Int
  cieNumber        Int
  marksObtained    Float
  maxMarks         Float          @default(50)
  enteredByUserId  Int
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  subject          Subject        @relation(fields: [subjectId], references: [id])
  enteredBy        User           @relation("EnteredBy", fields: [enteredByUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentProfileId, subjectId, cieNumber])
  @@index([studentProfileId])
  @@map("cie_marks")
}

model Notice {
  id             Int      @id @default(autoincrement())
  title          String
  content        String   @db.Text
  targetRole     Role?
  departmentId   Int?
  postedByUserId Int
  isActive       Boolean  @default(true)
  postedBy       User     @relation("PostedBy", fields: [postedByUserId], references: [id])

  createdAt DateTime @default(now())

  @@map("notices")
}

model AcademicCalendar {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  startDate   DateTime @db.Date
  endDate     DateTime? @db.Date
  type        String

  @@map("academic_calendar")
}
